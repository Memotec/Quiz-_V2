rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'tailieutbtt@gmail.com';
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity-specific validation helpers
    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.email is string && data.email.size() <= 200
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 150))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048))
        && data.keys().hasAll(['id', 'email', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 6;
    }

    function isValidExamHistoryItem(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.date is string && data.date.size() <= 64
        && data.mode is string && (data.mode == 'practice' || data.mode == 'exam')
        && data.categoryName is string && data.categoryName.size() <= 500
        && data.totalQuestions is int && data.totalQuestions >= 0 && data.totalQuestions <= 200
        && data.correctAnswersCount is int && data.correctAnswersCount >= 0 && data.correctAnswersCount <= 200
        && data.score is number && data.score >= 0.0 && data.score <= 10.0
        && data.timeSpentSeconds is int && data.timeSpentSeconds >= 0 && data.timeSpentSeconds <= 86400
        && data.passed is bool
        && data.keys().hasAll(['id', 'userId', 'date', 'mode', 'categoryName', 'totalQuestions', 'correctAnswersCount', 'score', 'timeSpentSeconds', 'passed', 'createdAt'])
        && data.keys().size() == 11;
    }

    // Rules for /users/{userId}
    match /users/{userId} {
      allow read, write: if true;

      // Rules for user's subcollection: /users/{userId}/history/{historyId}
      match /history/{historyId} {
        allow read, write: if true;
      }
    }

    // Rules for the collection group query of history documents
    match /{path=**}/history/{historyId} {
      allow read, write: if true;
    }

    // Rules for official predefined candidates management
    match /candidates/{candidateId} {
      allow read, write: if true;
    }
  }
}
